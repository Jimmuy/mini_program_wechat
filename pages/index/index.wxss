/* pages/index/index.wxss */
.hero-container {
  position: relative;
  min-height: 100vh;
  width: 100vw;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  /* overflow: hidden;  Removed to allow scrolling */
  background-color: #000;
  padding-bottom: 100rpx;
}

/* Background Ambience */
.ambience-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}

.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(120px);
  opacity: 0.2;
}

.blob-purple {
  top: -10%;
  left: -10%;
  width: 500rpx;
  height: 500rpx;
  background-color: var(--neon-purple);
  animation: pulse 8s infinite ease-in-out;
}

.blob-blue {
  bottom: -10%;
  right: -10%;
  width: 600rpx;
  height: 600rpx;
  background-color: var(--neon-blue);
  animation: pulse 8s infinite ease-in-out 2s;
}

@keyframes pulse {

  0%,
  100% {
    transform: scale(1);
    opacity: 0.2;
  }

  50% {
    transform: scale(1.2);
    opacity: 0.3;
  }
}

/* Hero Content */
.hero-content {
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 0 48rpx;
  max-width: 100%;
}

.badge {
  padding: 12rpx 32rpx;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background-color: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  backdrop-filter: blur(10px);
  margin-bottom: 64rpx;
}

.title {
  font-size: 120rpx;
  font-weight: 900;
  line-height: 1;
  margin-bottom: 48rpx;
  letter-spacing: -0.05em;
}

.gradient-text {
  background: linear-gradient(to right, #2563eb, #a855f7, #818cf8);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  background-size: 200% auto;
  animation: gradientX 5s ease infinite;
}

@keyframes gradientX {
  0% {
    background-position: 0% 50%;
  }

  50% {
    background-position: 100% 50%;
  }

  100% {
    background-position: 0% 50%;
  }
}

.subtitle {
  font-size: 36rpx;
  color: #9ca3af;
  font-weight: 300;
  margin-bottom: 96rpx;
  line-height: 1.6;
  max-width: 80%;
}

.explore-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 64rpx;
  background-color: #ffffff;
  color: #000000;
  font-weight: 700;
  font-size: 36rpx;
  border-radius: 999px;
  border: none;
  overflow: hidden;
  transition: all 0.3s ease;
}

.explore-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

/* Scroll Indicator */
.scroll-indicator {
  position: absolute;
  bottom: 80rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {

  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(20rpx);
  }
}

/* Animations */
.animate-fade-in {
  opacity: 0;
  animation: fadeIn 0.8s ease-out forwards;
}

.animate-slide-up {
  opacity: 0;
  transform: translateY(40rpx);
  animation: slideUp 0.8s ease-out forwards;
}

@keyframes fadeIn {
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.delay-200 {
  animation-delay: 0.2s;
}

.delay-400 {
  animation-delay: 0.4s;
}

.delay-600 {
  animation-delay: 0.6s;
}

.delay-800 {
  animation-delay: 0.8s;
}

/* Gear Showcase */
.gear-showcase {
  background-color: #000;
  padding: 80rpx 48rpx 160rpx;
  color: #fff;
}

.gear-header {
  text-align: center;
  margin-bottom: 96rpx;
}

.gear-title {
  font-size: 64rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.gear-subtitle {
  font-size: 28rpx;
  color: #9ca3af;
}

.gear-section {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
  margin-bottom: 160rpx;
}

.gear-content {
  order: 1;
}

.gear-image-container {
  order: 2;
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  background: linear-gradient(135deg, #111827, #000);
  border-radius: 32rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
  overflow: hidden;
  box-shadow: 0 0 40rpx rgba(0, 243, 255, 0.05);
}

.gear-image {
  width: 100%;
  height: 650rpx;
  /* 或者 height: 100%; 配合父容器高度 */
  display: block;
}

.gear-image-container.contain .gear-image {
  padding: 48rpx;
  box-sizing: border-box;
}

.gear-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent);
  pointer-events: none;
}

.gear-item-subtitle {
  font-family: monospace;
  color: var(--neon-blue);
  font-size: 24rpx;
  letter-spacing: 0.2em;
  margin-bottom: 16rpx;
}

.gear-item-title {
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.1;
  margin-bottom: 32rpx;
}

.gear-item-desc {
  font-size: 32rpx;
  color: #9ca3af;
  line-height: 1.6;
}

/* World Map Section */
.map-section {
  background-color: #000;
  padding: 80rpx 48rpx 200rpx;
  /* Extra padding at bottom for tab bar */
  color: #fff;
}

.map-header {
  text-align: center;
  margin-bottom: 64rpx;
}

.map-title {
  font-size: 64rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  background: linear-gradient(to right, #60a5fa, #a855f7);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.map-subtitle {
  font-size: 28rpx;
  color: #9ca3af;
}

.map-image-container {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 24rpx;
}

.map-image {
  width: 100%;
  border-radius: 24rpx;
  opacity: 0.8;
}
<!-- pages/index/index.wxml -->
<view class="hero-container">
  <!-- Background Ambience -->
  <view class="ambience-bg">
    <view class="blob blob-purple"></view>
    <view class="blob blob-blue"></view>
  </view>

  <!-- Hero Content -->
  <view class="hero-content">
    <view class="badge animate-fade-in delay-200">PORTFOLIO 2025</view>

    <view class="title animate-slide-up delay-400">
      <text class="gradient-text">{{name}}</text>
    </view>

    <view class="subtitle animate-slide-up delay-600">
      {{role}}
    </view>

    <view class="action-btn-container animate-slide-up delay-800">
      <button class="explore-btn" bindtap="navigateToGallery">
        <text>探索作品</text>
        <t-icon name="arrow-right" size="40rpx" color="#000" style="margin-left: 8rpx;" />
      </button>
    </view>
  </view>
</view>

<!-- Gear Showcase Section -->
<view class="gear-showcase">
  <view class="gear-header">
    <view class="gear-title">出行装备</view>
    <view class="gear-subtitle">工欲善其事，必先利其器</view>
  </view>

  <block wx:for="{{gearData}}" wx:key="title">
    <view class="gear-section {{item.align === 'right' ? 'align-right' : ''}}">
      <view class="gear-content">
        <view class="gear-item-subtitle">{{item.subtitle}}</view>
        <view class="gear-item-title">{{item.title}}</view>
        <view class="gear-item-desc">{{item.description}}</view>
      </view>

      <view class="gear-image-container {{item.variant}}">
        <t-image src="{{item.imageSrc}}" mode="{{item.variant === 'contain' ? 'aspectFit' : 'aspectFill'}}" class="gear-image" />
        <view class="gear-overlay"></view>
      </view>
    </view>
  </block>
</view>

<!-- World Map Section -->
<view class="map-section">
  <view class="map-header">
    <view class="map-title">我的足迹</view>
    <view class="map-subtitle">用镜头记录世界的每一个角落</view>
  </view>

  <view class="map-content">
    <view class="map-image-container">
      <image src="/assets/map_placeholder.png" mode="widthFix" class="map-image" />
    </view>
  </view>
</view>
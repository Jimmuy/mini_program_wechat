/* /pages/experience-detail/index.wxss */
page {
  background-color: #f4f5f7;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  min-height: 100vh;
}

.detail-container {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: #999;
}

/* 借用 home.wxss 的卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-content {
  padding: 32rpx;
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

/* 详情页的顶部卡片 */
.header-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(110, 100, 234, 0.3);
}

.header-role {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.header-company {
  font-size: 32rpx;
  font-weight: 500;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.header-time {
  font-size: 28rpx;
  font-weight: 300;
  opacity: 0.8;
}

/* 借用 home.wxss 的列表样式 */
.list-item-dot {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx; /* 增加详情页的行间距 */
}

.list-item-dot:last-child {
  margin-bottom: 0;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background-color: #667eea;
  border-radius: 50%;
  margin-right: 16rpx;
  margin-top: 10rpx;
  flex-shrink: 0;
}
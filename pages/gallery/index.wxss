/* pages/gallery/index.wxss */
.gallery-container {
  min-height: 100vh;
  background-color: #000;
  color: #fff;
  padding-bottom: 200rpx; /* Space for tab bar */
}

/* Header */
.header {
  padding: 120rpx 48rpx 64rpx;
}

.header-title {
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.1;
  margin-bottom: 24rpx;
  letter-spacing: -0.02em;
}

.text-neon-blue {
  color: var(--neon-blue);
  text-shadow: 0 0 20rpx rgba(0, 243, 255, 0.3);
}

.header-desc {
  font-size: 28rpx;
  color: #9ca3af;
  line-height: 1.6;
  max-width: 80%;
}

/* Cover List View */
.cover-list {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.cover-item {
  width: 100%;
}

.cover-image-container {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 32rpx;
}

.cover-location {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.cover-count {
  font-size: 24rpx;
  color: var(--neon-blue);
  font-family: monospace;
  letter-spacing: 0.1em;
}

.cover-desc {
  font-size: 28rpx;
  color: #9ca3af;
  padding: 0 8rpx;
}

/* Detail View */
.detail-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: rgba(0, 0, 0, 0.8);
  backdrop-filter: blur(20px);
  padding: 100rpx 32rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  pointer-events: auto; /* Ensure header is clickable */
}

.back-btn {
  padding: 16rpx;
  margin-left: -16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.back-arrow {
  color: #fff;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 700;
}

.photos-grid {
  column-count: 2;
  column-gap: 24rpx;
  padding: 24rpx;
}

.photo-item {
  break-inside: avoid;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.photo-img {
  width: 100%;
  display: block;
}

/* Lightbox */
.lightbox {
  position: fixed;
  inset: 0;
  z-index: 10000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.lightbox.visible {
  opacity: 1;
  pointer-events: auto;
}

.lightbox-bg {
  position: absolute;
  inset: 0;
  background-color: #000;
}

.lightbox-content {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.close-btn {
  position: absolute;
  top: 180rpx; /* Moved down to avoid capsule overlap */
  right: 40rpx;
  z-index: 20;
  padding: 20rpx;
}

.nav-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 20;
  padding: 40rpx;
}

.prev-btn { left: 0; }
.next-btn { right: 0; }

.lightbox-image-container {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lightbox-image {
  width: 100%;
  height: 100%;
}

/* Lightbox Info Panel */
.lightbox-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(20, 20, 20, 0.9);
  backdrop-filter: blur(20px);
  padding: 48rpx;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.lightbox-info.show {
  transform: translateY(0);
}

.lightbox-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.lightbox-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 32rpx;
}

.lightbox-exif {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding-top: 32rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.exif-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #9ca3af;
  background-color: rgba(255, 255, 255, 0.05);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* pages/resume/index.wxss */
.resume-container {
  min-height: 100vh;
  background-color: #000;
  color: #fff;
  padding-bottom: 48rpx;
}

/* Lock Screen */
.lock-screen {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.lock-card {
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.lock-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4rpx;
  background: linear-gradient(to right, var(--neon-blue), var(--neon-purple));
}

.lock-icon-container {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.lock-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.lock-desc {
  font-size: 28rpx;
  color: #9ca3af;
  margin-bottom: 48rpx;
}

.lock-hint {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.lock-form {
  width: 100%;
}

.lock-input {
  width: 100%;
  background: rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 0 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  color: #fff;
  text-align: left;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.input-placeholder {
  color: #666;
}

.input-error {
  border-color: #ef4444;
}

.error-msg {
  color: #ef4444;
  font-size: 24rpx;
  margin-bottom: 32rpx;
  height: 32rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.error-msg.visible {
  opacity: 1;
}

.unlock-btn {
  width: 100%;
  background: #fff;
  color: #000;
  font-weight: 700;
  border-radius: 16rpx;
  padding: 24rpx;
  border: none;
}

.unlock-btn:active {
  background: var(--neon-blue);
  color: #fff;
}

/* Resume Content */
.resume-content {
  padding: 160rpx 48rpx 48rpx;
}

.resume-header {
  margin-bottom: 96rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}

.page-title {
  font-size: 64rpx;
  font-weight: 700;
}

.verified-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(74, 222, 128, 0.1);
  color: #4ade80;
  padding: 8rpx 24rpx;
  border-radius: 999px;
  font-size: 24rpx;
  border: 1px solid rgba(74, 222, 128, 0.2);
}

.profile-section {
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  padding-bottom: 96rpx;
}

.profile-name {
  font-size: 64rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  background: linear-gradient(to right, #fff, #9ca3af);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.profile-title {
  font-size: 36rpx;
  color: var(--neon-blue);
  margin-bottom: 48rpx;
  font-weight: 300;
}

.basic-info-grid {
  display: grid;
  grid-template-columns: repeat(1, 1fr);
  gap: 24rpx;
}

.info-card {
  background: rgba(255, 255, 255, 0.05);
  padding: 32rpx;
  border-radius: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.info-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 30rpx;
  font-weight: 500;
}

/* Sections */
.section {
  margin-bottom: 96rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 48rpx;
}

.title-bar {
  width: 8rpx;
  height: 48rpx;
  border-radius: 999px;
}

.title-bar.purple {
  background-color: var(--neon-purple);
  box-shadow: 0 0 20rpx var(--neon-purple);
}

.title-bar.blue {
  background-color: var(--neon-blue);
  box-shadow: 0 0 20rpx var(--neon-blue);
}

.section-subtitle {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin: 64rpx 0 32rpx 0;
  padding-left: 24rpx;
  border-left: 4rpx solid var(--neon-purple);
}

.section-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 48rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.advantage-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.advantage-item:last-child {
  margin-bottom: 0;
}

.adv-icon {
  flex-shrink: 0;
  margin-top: 6rpx;
}

.adv-text {
  font-size: 28rpx;
  color: #d1d5db;
  line-height: 1.6;
}

/* Skills */
.skills-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24rpx;
}

.skill-card {
  background: rgba(255, 255, 255, 0.05);
  padding: 48rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.skill-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 32rpx;
}

.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.skill-tag {
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 999px;
  font-size: 24rpx;
  color: #d1d5db;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.skill-desc {
  font-size: 28rpx;
  color: #9ca3af;
  line-height: 1.6;
}

/* Work Experience */
.experience-list {
  display: flex;
  flex-direction: column;
  gap: 64rpx;
}

.exp-item {
  position: relative;
  padding-left: 48rpx;
  border-left: 1px solid rgba(255, 255, 255, 0.1);
  cursor: pointer;
  transition: all 0.3s ease;
}

.exp-item:active {
  transform: translateX(8rpx);
}

.exp-dot {
  position: absolute;
  left: -10rpx;
  top: 12rpx;
  width: 20rpx;
  height: 20rpx;
  background-color: var(--neon-blue);
  border-radius: 50%;
  box-shadow: 0 0 20rpx var(--neon-blue);
}

.exp-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.exp-role {
  font-size: 36rpx;
  font-weight: 700;
}

.exp-time {
  font-size: 24rpx;
  color: var(--neon-blue);
  background: rgba(0, 243, 255, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  align-self: flex-start;
  border: 1px solid rgba(0, 243, 255, 0.2);
}

.exp-company {
  font-size: 32rpx;
  color: var(--neon-purple);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.exp-summary-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.exp-summary {
  flex: 1;
  font-size: 28rpx;
  color: #9ca3af;
  font-style: italic;
  padding-left: 24rpx;
  border-left: 2px solid rgba(255, 255, 255, 0.1);
  line-height: 1.6;
}

.exp-chevron {
  flex-shrink: 0;
  margin-top: 4rpx;
}

.detail-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #d1d5db;
  line-height: 1.6;
}

.detail-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #4b5563;
  border-radius: 50%;
  margin-top: 12rpx;
  flex-shrink: 0;
}

/* Personal Projects */
.projects-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24rpx;
}

.project-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 40rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
  display: flex;
  gap: 32rpx;
  align-items: center;
  transition: all 0.3s ease;
}

.project-card:active {
  background: rgba(255, 255, 255, 0.08);
  transform: scale(0.98);
}

.project-icon-container {
  width: 96rpx;
  height: 96rpx;
  background: rgba(188, 19, 254, 0.1);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 1px solid rgba(188, 19, 254, 0.2);
}

.project-info {
  flex: 1;
}

.project-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.project-desc {
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.project-action {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #bc13fe;
  font-weight: 500;
}

/* About Me */
.about-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05), transparent);
  border-radius: 24rpx;
  padding: 48rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
  display: grid;
  grid-template-columns: 1fr;
  gap: 24rpx;
}

.about-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: #d1d5db;
}

/* Animations */
.animate-fade-in {
  opacity: 0;
  animation: fadeIn 0.8s ease-out forwards;
}

.animate-slide-up {
  opacity: 0;
  transform: translateY(40rpx);
  animation: slideUp 0.8s ease-out forwards;
}

@keyframes fadeIn {
  to { opacity: 1; }
}

@keyframes slideUp {
  to { opacity: 1; transform: translateY(0); }
}

.delay-100 { animation-delay: 0.1s; }
.delay-200 { animation-delay: 0.2s; }
.delay-300 { animation-delay: 0.3s; }
.delay-400 { animation-delay: 0.4s; }
.delay-450 { animation-delay: 0.45s; }
.delay-500 { animation-delay: 0.5s; }
/* Experience Popup Styles */
.experience-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.experience-popup.show {
  visibility: visible;
  opacity: 1;
}

.popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(4px);
}

.popup-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 80vh;
  background: linear-gradient(to bottom, #0a0a0a, #000);
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  border-top: 1px solid rgba(188, 19, 254, 0.3);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.8);
  width: 100%;
  box-sizing: border-box;
}

.experience-popup.show .popup-content {
  transform: translateY(0);
}

.popup-header {
  padding: 40rpx 32rpx 24rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
  box-sizing: border-box;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.popup-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #9ca3af;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  transition: all 0.2s;
}

.popup-close:active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.95);
}

.popup-body {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 32rpx;
  /* Add extra padding for tab bar (approx 120rpx) + safe area */
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.exp-detail-header {
  margin-bottom: 40rpx;
  padding-bottom: 24rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  width: 100%;
  box-sizing: border-box;
}

.exp-detail-role {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  line-height: 1.3;
  word-wrap: break-word;
  word-break: break-word;
}

.exp-detail-time {
  font-size: 22rpx;
  color: var(--neon-blue);
  background: rgba(0, 243, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 20rpx;
  border: 1px solid rgba(0, 243, 255, 0.2);
}

.exp-detail-company {
  font-size: 28rpx;
  color: var(--neon-purple);
  margin-bottom: 20rpx;
  font-weight: 600;
  line-height: 1.4;
  word-wrap: break-word;
}

.exp-detail-summary {
  font-size: 26rpx;
  color: #9ca3af;
  font-style: italic;
  line-height: 1.6;
  padding-left: 20rpx;
  border-left: 3px solid rgba(188, 19, 254, 0.3);
  word-wrap: break-word;
  word-break: break-word;
}

.exp-detail-section {
  margin-top: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.detail-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
  border-left: 4rpx solid var(--neon-purple);
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.detail-list-item {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  width: 100%;
  box-sizing: border-box;
}

.detail-bullet {
  color: var(--neon-blue);
  font-size: 28rpx;
  line-height: 1.6;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.detail-text {
  flex: 1;
  font-size: 26rpx;
  color: #d1d5db;
  line-height: 1.6;
  word-wrap: break-word;
  word-break: break-word;
  overflow-wrap: break-word;
  min-width: 0; /* Critical for flex child text wrapping */
}

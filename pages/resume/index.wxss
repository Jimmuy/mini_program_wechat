/* pages/resume/index.wxss */
.resume-container {
  min-height: 100vh;
  background-color: #000;
  color: #fff;
  padding-bottom: 48rpx;
}

/* Lock Screen */
.lock-screen {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.lock-card {
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.lock-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4rpx;
  background: linear-gradient(to right, var(--neon-blue), var(--neon-purple));
}

.lock-icon-container {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.lock-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.lock-desc {
  font-size: 28rpx;
  color: #9ca3af;
  margin-bottom: 48rpx;
}

.lock-hint {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.lock-form {
  width: 100%;
}

.lock-input {
  width: 100%;
  background: rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 0 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  color: #fff;
  text-align: left;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.input-placeholder {
  color: #666;
}

.input-error {
  border-color: #ef4444;
}

.error-msg {
  color: #ef4444;
  font-size: 24rpx;
  margin-bottom: 32rpx;
  height: 32rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.error-msg.visible {
  opacity: 1;
}

.unlock-btn {
  width: 100%;
  background: #fff;
  color: #000;
  font-weight: 700;
  border-radius: 16rpx;
  padding: 24rpx;
  border: none;
}

.unlock-btn:active {
  background: var(--neon-blue);
  color: #fff;
}

/* Resume Content */
.resume-content {
  padding: 160rpx 48rpx 48rpx;
}

.resume-header {
  margin-bottom: 96rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}

.page-title {
  font-size: 64rpx;
  font-weight: 700;
}

.verified-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(74, 222, 128, 0.1);
  color: #4ade80;
  padding: 8rpx 24rpx;
  border-radius: 999px;
  font-size: 24rpx;
  border: 1px solid rgba(74, 222, 128, 0.2);
}

.profile-section {
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  padding-bottom: 96rpx;
}

.profile-name {
  font-size: 64rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  background: linear-gradient(to right, #fff, #9ca3af);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.profile-title {
  font-size: 36rpx;
  color: var(--neon-blue);
  margin-bottom: 48rpx;
  font-weight: 300;
}

.basic-info-grid {
  display: grid;
  grid-template-columns: repeat(1, 1fr);
  gap: 24rpx;
}

.info-card {
  background: rgba(255, 255, 255, 0.05);
  padding: 32rpx;
  border-radius: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.info-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 30rpx;
  font-weight: 500;
}

/* Sections */
.section {
  margin-bottom: 96rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 48rpx;
}

.title-bar {
  width: 8rpx;
  height: 48rpx;
  border-radius: 999px;
}

.title-bar.purple {
  background-color: var(--neon-purple);
  box-shadow: 0 0 20rpx var(--neon-purple);
}

.title-bar.blue {
  background-color: var(--neon-blue);
  box-shadow: 0 0 20rpx var(--neon-blue);
}

.section-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 48rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.advantage-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.advantage-item:last-child {
  margin-bottom: 0;
}

.adv-icon {
  flex-shrink: 0;
  margin-top: 6rpx;
}

.adv-text {
  font-size: 28rpx;
  color: #d1d5db;
  line-height: 1.6;
}

/* Skills */
.skills-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24rpx;
}

.skill-card {
  background: rgba(255, 255, 255, 0.05);
  padding: 48rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.skill-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 32rpx;
}

.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.skill-tag {
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 999px;
  font-size: 24rpx;
  color: #d1d5db;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.skill-desc {
  font-size: 28rpx;
  color: #9ca3af;
  line-height: 1.6;
}

/* Work Experience */
.experience-list {
  display: flex;
  flex-direction: column;
  gap: 64rpx;
}

.exp-item {
  position: relative;
  padding-left: 48rpx;
  border-left: 1px solid rgba(255, 255, 255, 0.1);
}

.exp-dot {
  position: absolute;
  left: -10rpx;
  top: 12rpx;
  width: 20rpx;
  height: 20rpx;
  background-color: var(--neon-blue);
  border-radius: 50%;
  box-shadow: 0 0 20rpx var(--neon-blue);
}

.exp-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.exp-role {
  font-size: 36rpx;
  font-weight: 700;
}

.exp-time {
  font-size: 24rpx;
  color: var(--neon-blue);
  background: rgba(0, 243, 255, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  align-self: flex-start;
  border: 1px solid rgba(0, 243, 255, 0.2);
}

.exp-company {
  font-size: 32rpx;
  color: var(--neon-purple);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.exp-summary {
  font-size: 28rpx;
  color: #9ca3af;
  font-style: italic;
  margin-bottom: 32rpx;
  padding-left: 24rpx;
  border-left: 2px solid rgba(255, 255, 255, 0.1);
}

.detail-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #d1d5db;
  line-height: 1.6;
}

.detail-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #4b5563;
  border-radius: 50%;
  margin-top: 12rpx;
  flex-shrink: 0;
}

/* About Me */
.about-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05), transparent);
  border-radius: 24rpx;
  padding: 48rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
  display: grid;
  grid-template-columns: 1fr;
  gap: 24rpx;
}

.about-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: #d1d5db;
}

/* Animations */
.animate-fade-in {
  opacity: 0;
  animation: fadeIn 0.8s ease-out forwards;
}

.animate-slide-up {
  opacity: 0;
  transform: translateY(40rpx);
  animation: slideUp 0.8s ease-out forwards;
}

@keyframes fadeIn {
  to { opacity: 1; }
}

@keyframes slideUp {
  to { opacity: 1; transform: translateY(0); }
}

.delay-100 { animation-delay: 0.1s; }
.delay-200 { animation-delay: 0.2s; }
.delay-300 { animation-delay: 0.3s; }
.delay-400 { animation-delay: 0.4s; }
.delay-500 { animation-delay: 0.5s; }
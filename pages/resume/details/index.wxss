/* pages/resume/details/index.wxss */
.detail-container {
  min-height: 100vh;
  background-color: #000;
  color: #fff;
  padding-bottom: 48rpx;
}

/* Header */
.detail-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: rgba(0, 0, 0, 0.9);
  backdrop-filter: blur(20px);
  padding: 100rpx 32rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.back-btn {
  padding: 20rpx;
  margin-left: -20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
}

/* Content */
.detail-content {
  padding: 48rpx;
}

/* Experience Header Section */
.exp-header-section {
  margin-bottom: 64rpx;
  padding-bottom: 48rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.exp-role {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  background: linear-gradient(to right, #fff, #9ca3af);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.exp-time {
  font-size: 26rpx;
  color: var(--neon-blue);
  background: rgba(0, 243, 255, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 24rpx;
  border: 1px solid rgba(0, 243, 255, 0.2);
}

.exp-company {
  font-size: 36rpx;
  color: var(--neon-purple);
  margin-bottom: 24rpx;
  font-weight: 600;
}

.exp-summary {
  font-size: 28rpx;
  color: #9ca3af;
  font-style: italic;
  line-height: 1.6;
  padding-left: 24rpx;
  border-left: 3px solid rgba(188, 19, 254, 0.3);
}

/* Responsibilities Section */
.responsibilities-section {
  margin-top: 48rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 32rpx;
}

.title-bar {
  width: 6rpx;
  height: 40rpx;
  background-color: var(--neon-purple);
  border-radius: 999px;
  box-shadow: 0 0 20rpx var(--neon-purple);
}

.responsibilities-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.responsibility-item {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.bullet-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: var(--neon-blue);
  border-radius: 50%;
  margin-top: 12rpx;
  flex-shrink: 0;
  box-shadow: 0 0 10rpx var(--neon-blue);
}

.responsibility-text {
  flex: 1;
  font-size: 28rpx;
  color: #d1d5db;
  line-height: 1.7;
}

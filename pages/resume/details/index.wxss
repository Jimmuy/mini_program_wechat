@import '../../../style/global.wxss';
page {
  width: 100vw;
}

.resume-detail-page {
  padding: 32rpx;
  background-color: #f7f7f7;
}

.resume-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.resume-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.resume-title {
  font-size: 32rpx;
  color: #666;
  display: block;
  margin-top: 8rpx;
}

.resume-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  border-bottom: 2rpx solid #eee;
  padding-bottom: 16rpx;
}

.section-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

.section-content text {
  display: block;
  margin-bottom: 8rpx;
}

.item-title {
  font-weight: bold;
  color: #333;
  margin-top: 16rpx;
}

.item-date {
  color: #999;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.t-toast__content {
  z-index: 12000 !important;
}



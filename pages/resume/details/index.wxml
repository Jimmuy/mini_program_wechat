<!-- pages/resume/details/index.wxml -->
<view class="detail-container">
  <!-- Header with Back Button -->
  <view class="detail-header">
    <view class="back-btn" bindtap="goBack">
      <t-icon name="arrow-left" size="48rpx" color="#fff" />
    </view>
    <view class="header-title">工作经历详情</view>
  </view>

  <view class="detail-content" wx:if="{{experience}}">
    <!-- Experience Header -->
    <view class="exp-header-section">
      <view class="exp-role">{{experience.role}}</view>
      <view class="exp-time">{{experience.time}}</view>
      <view class="exp-company">{{experience.company}}</view>
      <view class="exp-summary">{{experience.summary}}</view>
    </view>

    <!-- Detailed Responsibilities -->
    <view class="responsibilities-section">
      <view class="section-title">
        <view class="title-bar"></view>
        <text>工作内容</text>
      </view>
      <view class="responsibilities-list">
        <block wx:for="{{experience.details}}" wx:key="*this">
          <view class="responsibility-item">
            <view class="bullet-dot"></view>
            <text class="responsibility-text">{{item}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>
